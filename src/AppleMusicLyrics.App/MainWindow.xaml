<Window x:Class="AppleMusicLyrics.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Apple Music Lyrics"
        Width="720"
        Height="240"
        MinWidth="320"
        MinHeight="140"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
  <Grid>
    <Grid.Resources>
      <Style TargetType="{x:Type primitives:Thumb}">
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type primitives:Thumb}">
              <Border Background="Transparent" />
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </Grid.Resources>
    <Grid x:Name="ResizeLayer"
          Margin="8"
          Panel.ZIndex="10"
          Visibility="Visible">
      <primitives:Thumb HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Height="12"
                        Background="Transparent"
                        Cursor="SizeNS"
                        Tag="Top"
                        PreviewMouseLeftButtonDown="ResizeThumb_OnPreviewMouseLeftButtonDown" />
      <primitives:Thumb HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Height="12"
                        Background="Transparent"
                        Cursor="SizeNS"
                        Tag="Bottom"
                        PreviewMouseLeftButtonDown="ResizeThumb_OnPreviewMouseLeftButtonDown" />
      <primitives:Thumb HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Width="12"
                        Background="Transparent"
                        Cursor="SizeWE"
                        Tag="Left"
                        PreviewMouseLeftButtonDown="ResizeThumb_OnPreviewMouseLeftButtonDown" />
      <primitives:Thumb HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Width="12"
                        Background="Transparent"
                        Cursor="SizeWE"
                        Tag="Right"
                        PreviewMouseLeftButtonDown="ResizeThumb_OnPreviewMouseLeftButtonDown" />

      <primitives:Thumb HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Width="18"
                        Height="18"
                        Background="Transparent"
                        Cursor="SizeNWSE"
                        Tag="TopLeft"
                        PreviewMouseLeftButtonDown="ResizeThumb_OnPreviewMouseLeftButtonDown" />
      <primitives:Thumb HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="18"
                        Height="18"
                        Background="Transparent"
                        Cursor="SizeNESW"
                        Tag="TopRight"
                        PreviewMouseLeftButtonDown="ResizeThumb_OnPreviewMouseLeftButtonDown" />
      <primitives:Thumb HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Width="18"
                        Height="18"
                        Background="Transparent"
                        Cursor="SizeNESW"
                        Tag="BottomLeft"
                        PreviewMouseLeftButtonDown="ResizeThumb_OnPreviewMouseLeftButtonDown" />
      <primitives:Thumb HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Width="18"
                        Height="18"
                        Background="Transparent"
                        Cursor="SizeNWSE"
                        Tag="BottomRight"
                        PreviewMouseLeftButtonDown="ResizeThumb_OnPreviewMouseLeftButtonDown" />
    </Grid>

    <Border x:Name="ShellBorder"
            Margin="14"
            Padding="12"
            CornerRadius="16"
            Background="#C8141416"
            MouseLeftButtonDown="ShellBorder_OnMouseLeftButtonDown">
      <Grid x:Name="ContentRoot">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   x:Name="HeaderPanel"
                   LastChildFill="False">
          <TextBlock x:Name="SubtitleText"
                     FontSize="13"
                     Foreground="#D0D0D0"
                     Opacity="0.9"
                     TextTrimming="CharacterEllipsis"
                     Text="Waiting for Apple Music..." />
          <TextBlock x:Name="StatusText"
                     Margin="12,0,0,0"
                     FontSize="12"
                     Foreground="#8D8D8D"
                     DockPanel.Dock="Right"
                     Text="Idle" />
        </DockPanel>

        <Grid x:Name="LyricPanel"
              Grid.Row="1"
              Margin="0,8,0,6">
          <Grid.RowDefinitions>
            <RowDefinition x:Name="PreviousLyricRow" Height="*" />
            <RowDefinition x:Name="CurrentLyricRow" Height="Auto" />
            <RowDefinition x:Name="NextLyricRow" Height="*" />
          </Grid.RowDefinitions>

          <TextBlock x:Name="PreviousLyricText"
                     Grid.Row="0"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="#8F9499"
                     FontSize="22"
                     TextWrapping="Wrap"
                     MaxHeight="36"
                     Text="Previous line" />

          <TextBlock x:Name="CurrentLyricText"
                     Grid.Row="1"
                     Margin="0,4,0,4"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     MaxWidth="1200"
                     TextAlignment="Center"
                     Foreground="White"
                     FontSize="40"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"
                     TextTrimming="None"
                     RenderTransformOrigin="0.5,0.5"
                     Text="Current lyric line">
            <TextBlock.RenderTransform>
              <TranslateTransform x:Name="CurrentLyricTransform" />
            </TextBlock.RenderTransform>
            <TextBlock.Effect>
              <DropShadowEffect x:Name="CurrentLyricGlowEffect"
                                BlurRadius="22"
                                ShadowDepth="0"
                                Color="#FFFFFFFF"
                                Opacity="0.38" />
            </TextBlock.Effect>
          </TextBlock>

          <TextBlock x:Name="NextLyricText"
                     Grid.Row="2"
                     Margin="0,0,0,0"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="#8F9499"
                     FontSize="22"
                     TextWrapping="Wrap"
                     MaxHeight="36"
                     Text="Next line" />
        </Grid>

        <!-- Frozen snapshot of the outgoing lyrics, used to crossfade into the new ones -->
        <Image x:Name="LyricGhostImage"
               Grid.Row="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="None"
               IsHitTestVisible="False"
               Visibility="Collapsed" />

        <StackPanel x:Name="FooterPanel"
                    Grid.Row="2">
          <TextBlock x:Name="PlayerText"
                     FontSize="12"
                     Foreground="#A6A6A6"
                     Text="Waiting for media session..." />
          <TextBlock x:Name="TimingText"
                     Margin="0,4,0,0"
                     FontSize="11"
                     Foreground="#6F6F6F"
                     Text="Waiting for playback clock..." />
          <TextBlock x:Name="PathText"
                     Margin="0,4,0,0"
                     FontSize="10"
                     Foreground="#5A5A5A"
                     TextTrimming="CharacterEllipsis"
                     Text="Waiting for lyric cache path..." />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
