<Window x:Class="AppleMusicLyrics.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay Settings"
        Width="560"
        Height="760"
        MinWidth="500"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Foreground="White"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        Background="#0B0C10">
  <Window.Resources>

    <!-- Palette -->
    <Color x:Key="AccentColor">#FF3B60</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF3B60" />
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Offset="0" Color="#FF4F7E" />
      <GradientStop Offset="1" Color="#FF2D55" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardBrush" Color="#16181F" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#262B35" />
    <SolidColorBrush x:Key="InputBrush" Color="#0E1015" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#2E3540" />
    <SolidColorBrush x:Key="TrackBrush" Color="#2B313B" />
    <SolidColorBrush x:Key="KnobBrush" Color="#B7BEC9" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F3F6FB" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#969FAD" />

    <!-- Section + label typography -->
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
      <Setter Property="Margin" Value="2,0,0,16" />
    </Style>
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="ValueLabelStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Card -->
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBrush}" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="0,0,0,14" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Toggle switch (CheckBox) -->
    <Style x:Key="ToggleStyle" TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="13.5" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Border Background="Transparent" Padding="0,9">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ContentPresenter VerticalAlignment="Center" />
                <Border x:Name="Track"
                        Grid.Column="1"
                        Width="44"
                        Height="26"
                        CornerRadius="13"
                        Background="{StaticResource TrackBrush}"
                        VerticalAlignment="Center">
                  <Ellipse x:Name="Knob"
                           Width="18"
                           Height="18"
                           Margin="4,0,0,0"
                           HorizontalAlignment="Left"
                           Fill="{StaticResource KnobBrush}" />
                </Border>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentGradient}" />
                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="Knob" Property="Margin" Value="0,0,4,0" />
                <Setter TargetName="Knob" Property="Fill" Value="White" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.82" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Slider -->
    <Style x:Key="SliderThumbStyle" TargetType="Thumb">
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Grid>
              <Ellipse Width="18" Height="18" Fill="White" />
              <Ellipse Width="18" Height="18" Fill="{StaticResource AccentBrush}" Opacity="0" x:Name="Glow" />
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="ModernSliderStyle" TargetType="Slider">
      <Setter Property="Height" Value="26" />
      <Setter Property="Margin" Value="0,2,0,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid VerticalAlignment="Center">
              <Border Height="6" CornerRadius="3" Background="{StaticResource TrackBrush}" VerticalAlignment="Center" />
              <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge" Focusable="False" IsTabStop="False">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Height="6" CornerRadius="3" Background="{StaticResource AccentGradient}" VerticalAlignment="Center" />
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge" Focusable="False" IsTabStop="False">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Style="{StaticResource SliderThumbStyle}" />
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- TextBox -->
    <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="CaretBrush" Value="White" />
      <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="Bd"
                    CornerRadius="9"
                    Background="{StaticResource InputBrush}"
                    BorderBrush="{StaticResource InputBorderBrush}"
                    BorderThickness="1"
                    Padding="11,8">
              <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ComboBox -->
    <ControlTemplate x:Key="ComboToggleTemplate" TargetType="ToggleButton">
      <Border x:Name="Bd"
              CornerRadius="9"
              Background="{StaticResource InputBrush}"
              BorderBrush="{StaticResource InputBorderBrush}"
              BorderThickness="1"
              Padding="11,8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <ContentPresenter Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{Binding Path=SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
          <Path Grid.Column="1"
                Width="10" Height="6"
                VerticalAlignment="Center"
                Stretch="Fill"
                Fill="{StaticResource SecondaryTextBrush}"
                Data="M0,0 L4,4 L8,0 Z" />
        </Grid>
      </Border>
      <ControlTemplate.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter TargetName="Bd" Property="BorderBrush" Value="#3C4654" />
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>
    <Style x:Key="EditorComboBoxItemStyle" TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="7" Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#232A34" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="EditorComboBoxStyle" TargetType="ComboBox">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="ItemContainerStyle" Value="{StaticResource EditorComboBoxItemStyle}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton Focusable="False"
                            ClickMode="Press"
                            Template="{StaticResource ComboToggleTemplate}"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
              <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                     Placement="Bottom"
                     AllowsTransparency="True"
                     PopupAnimation="Slide"
                     Focusable="False">
                <Border Margin="0,6,0,0"
                        MaxHeight="260"
                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                        Background="#14171D"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="6">
                  <ScrollViewer>
                    <ItemsPresenter />
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Buttons -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    CornerRadius="10"
                    Background="#1E232B"
                    BorderBrush="{StaticResource InputBorderBrush}"
                    BorderThickness="1"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#272D37" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#171B22" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="MinWidth" Value="100" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    CornerRadius="10"
                    Background="{StaticResource AccentGradient}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.78" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="ActionButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" CornerRadius="8" Background="#222831" Padding="12,8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#2B323D" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Scrollbar -->
    <Style TargetType="ScrollBar">
      <Setter Property="Width" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid Background="Transparent">
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb>
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4" Background="#39414D" Margin="2,0" />
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Helper: a label + value row above a slider -->
    <Style x:Key="SliderHeaderGridStyle" TargetType="Grid">
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

  </Window.Resources>

  <Border>
    <Border.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
        <GradientStop Offset="0" Color="#0C0E13" />
        <GradientStop Offset="1" Color="#121620" />
      </LinearGradientBrush>
    </Border.Background>

    <Grid Margin="22">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,20">
        <Border Width="44" Height="44" CornerRadius="13" Background="{StaticResource AccentGradient}" VerticalAlignment="Center">
          <Path Width="20" Height="22"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Stretch="Uniform"
                Fill="White"
                Data="M690 194c18-4 35 10 35 29v322c0 55-49 100-109 100c-51 0-91-30-91-72s40-72 91-72c25 0 48 8 66 21V322L446 371v235c0 55-49 100-109 100c-51 0-91-30-91-72s40-72 91-72c25 0 48 8 66 21V281c0-15 11-28 26-31l261-56z" />
        </Border>
        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
          <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="Overlay Settings" />
          <TextBlock FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" Text="Apple Music Lyrics" />
        </StackPanel>
      </StackPanel>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
        <StackPanel>

          <!-- Behavior -->
          <Border Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="BEHAVIOR" />
              <CheckBox x:Name="PureModeCheckBox" Style="{StaticResource ToggleStyle}" Content="Pure mode" />
              <CheckBox x:Name="ClickThroughCheckBox" Style="{StaticResource ToggleStyle}" Content="Click through" />
              <CheckBox x:Name="SingleLineModeCheckBox" Style="{StaticResource ToggleStyle}" Content="Single-line mode" Checked="LayoutModeCheckBox_OnChanged" Unchecked="LayoutModeCheckBox_OnChanged" />
              <CheckBox x:Name="TwoLineModeCheckBox" Style="{StaticResource ToggleStyle}" Content="Two-line mode (current + next)" Checked="LayoutModeCheckBox_OnChanged" Unchecked="LayoutModeCheckBox_OnChanged" />
              <CheckBox x:Name="ShowDebugPanelCheckBox" Style="{StaticResource ToggleStyle}" Content="Show debug panel" />
            </StackPanel>
          </Border>

          <!-- Visibility -->
          <Border Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="VISIBILITY" />
              <CheckBox x:Name="AutoHideCheckBox" Style="{StaticResource ToggleStyle}" Content="Fade out when no lyrics are available" />
              <CheckBox x:Name="FadeWhenPausedCheckBox" Style="{StaticResource ToggleStyle}" Content="Fade out while paused" />
              <CheckBox x:Name="HoverFadeCheckBox" Style="{StaticResource ToggleStyle}" Content="Dim while the mouse is over the overlay" />

              <Grid Style="{StaticResource SliderHeaderGridStyle}" Margin="0,12,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Fade duration" />
                <TextBlock x:Name="HoverFadeDurationValueText" Grid.Column="1" Style="{StaticResource ValueLabelStyle}" Text="0.30s" />
              </Grid>
              <Slider x:Name="HoverFadeDurationSlider" Style="{StaticResource ModernSliderStyle}"
                      Minimum="0.05" Maximum="1.0" TickFrequency="0.05" Value="0.30" ValueChanged="SliderValueChanged" />

              <Grid Style="{StaticResource SliderHeaderGridStyle}" Margin="0,16,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Opacity while dimmed" />
                <TextBlock x:Name="HoverFadeMinOpacityValueText" Grid.Column="1" Style="{StaticResource ValueLabelStyle}" Text="10%" />
              </Grid>
              <Slider x:Name="HoverFadeMinOpacitySlider" Style="{StaticResource ModernSliderStyle}"
                      Minimum="0" Maximum="0.5" TickFrequency="0.05" Value="0.10" ValueChanged="SliderValueChanged" />
            </StackPanel>
          </Border>

          <!-- Timing -->
          <Border Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="TIMING" />
              <Grid Style="{StaticResource SliderHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Lyrics lead time" />
                <TextBlock x:Name="LyricsOffsetValueText" Grid.Column="1" Style="{StaticResource ValueLabelStyle}" Text="0.28s" />
              </Grid>
              <Slider x:Name="LyricsOffsetSlider" Style="{StaticResource ModernSliderStyle}"
                      Minimum="-0.10" Maximum="0.80" TickFrequency="0.02" Value="0.28" ValueChanged="SliderValueChanged" />
            </StackPanel>
          </Border>

          <!-- Window -->
          <Border Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="WINDOW" />
              <Grid Style="{StaticResource SliderHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Window opacity" />
                <TextBlock x:Name="OverlayOpacityValueText" Grid.Column="1" Style="{StaticResource ValueLabelStyle}" Text="100%" />
              </Grid>
              <Slider x:Name="OverlayOpacitySlider" Style="{StaticResource ModernSliderStyle}"
                      Minimum="0.2" Maximum="1.0" TickFrequency="0.05" Value="1.0" ValueChanged="SliderValueChanged" />

              <Grid Style="{StaticResource SliderHeaderGridStyle}" Margin="0,16,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Background opacity" />
                <TextBlock x:Name="BackgroundAlphaValueText" Grid.Column="1" Style="{StaticResource ValueLabelStyle}" Text="78%" />
              </Grid>
              <Slider x:Name="BackgroundAlphaSlider" Style="{StaticResource ModernSliderStyle}"
                      Minimum="0" Maximum="100" TickFrequency="2" Value="78" ValueChanged="SliderValueChanged" />
            </StackPanel>
          </Border>

          <!-- Typography -->
          <Border Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="TYPOGRAPHY" />
              <Grid Style="{StaticResource SliderHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Current lyric size" />
                <TextBlock x:Name="MaxCurrentFontValueText" Grid.Column="1" Style="{StaticResource ValueLabelStyle}" Text="40px" />
              </Grid>
              <Slider x:Name="MaxCurrentFontSlider" Style="{StaticResource ModernSliderStyle}"
                      Minimum="24" Maximum="72" TickFrequency="1" Value="40" ValueChanged="SliderValueChanged" />

              <Grid Style="{StaticResource SliderHeaderGridStyle}" Margin="0,16,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Context lyric size cap" />
                <TextBlock x:Name="ContextFontValueText" Grid.Column="1" Style="{StaticResource ValueLabelStyle}" Text="24px" />
              </Grid>
              <Slider x:Name="ContextFontSlider" Style="{StaticResource ModernSliderStyle}"
                      Minimum="12" Maximum="36" TickFrequency="1" Value="24" ValueChanged="SliderValueChanged" />

              <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,16,0,7" Text="Font family" HorizontalAlignment="Left" />
              <ComboBox x:Name="FontFamilyComboBox" Style="{StaticResource EditorComboBoxStyle}" />
            </StackPanel>
          </Border>

          <!-- Color & Glow -->
          <Border Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="COLOR &amp; GLOW" />

              <Grid Style="{StaticResource SliderHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Glow opacity" />
                <TextBlock x:Name="GlowOpacityValueText" Grid.Column="1" Style="{StaticResource ValueLabelStyle}" Text="42%" />
              </Grid>
              <Slider x:Name="GlowOpacitySlider" Style="{StaticResource ModernSliderStyle}"
                      Minimum="0" Maximum="1.0" TickFrequency="0.05" Value="0.42" ValueChanged="SliderValueChanged" />

              <UniformGrid Margin="0,18,0,0" Columns="2">
                <StackPanel Margin="0,0,8,0">
                  <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,7" HorizontalAlignment="Left" Text="Current line" />
                  <DockPanel LastChildFill="False">
                    <Border x:Name="CurrentColorPreview" Width="34" Height="34" CornerRadius="9" BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" DockPanel.Dock="Left" />
                    <TextBox x:Name="CurrentColorTextBox" Width="86" Margin="10,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left" Style="{StaticResource EditorTextBoxStyle}" Text="#FFFFFF" />
                    <Button Content="Pick" Tag="Current" Margin="8,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left" Style="{StaticResource ActionButtonStyle}" Click="PickColorButton_OnClick" />
                  </DockPanel>
                </StackPanel>
                <StackPanel Margin="8,0,0,0">
                  <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,7" HorizontalAlignment="Left" Text="Context line" />
                  <DockPanel LastChildFill="False">
                    <Border x:Name="ContextColorPreview" Width="34" Height="34" CornerRadius="9" BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" DockPanel.Dock="Left" />
                    <TextBox x:Name="ContextColorTextBox" Width="86" Margin="10,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left" Style="{StaticResource EditorTextBoxStyle}" Text="#C8C8C8" />
                    <Button Content="Pick" Tag="Context" Margin="8,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left" Style="{StaticResource ActionButtonStyle}" Click="PickColorButton_OnClick" />
                  </DockPanel>
                </StackPanel>
              </UniformGrid>

              <UniformGrid Margin="0,16,0,0" Columns="2">
                <StackPanel Margin="0,0,8,0">
                  <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,7" HorizontalAlignment="Left" Text="Paused line" />
                  <DockPanel LastChildFill="False">
                    <Border x:Name="PausedColorPreview" Width="34" Height="34" CornerRadius="9" BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" DockPanel.Dock="Left" />
                    <TextBox x:Name="PausedColorTextBox" Width="86" Margin="10,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left" Style="{StaticResource EditorTextBoxStyle}" Text="#AAAAAA" />
                    <Button Content="Pick" Tag="Paused" Margin="8,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left" Style="{StaticResource ActionButtonStyle}" Click="PickColorButton_OnClick" />
                  </DockPanel>
                </StackPanel>
                <StackPanel Margin="8,0,0,0">
                  <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,7" HorizontalAlignment="Left" Text="Glow" />
                  <DockPanel LastChildFill="False">
                    <Border x:Name="GlowColorPreview" Width="34" Height="34" CornerRadius="9" BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" DockPanel.Dock="Left" />
                    <TextBox x:Name="GlowColorTextBox" Width="86" Margin="10,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left" Style="{StaticResource EditorTextBoxStyle}" Text="#FFFFFF" />
                    <Button Content="Pick" Tag="Glow" Margin="8,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left" Style="{StaticResource ActionButtonStyle}" Click="PickColorButton_OnClick" />
                  </DockPanel>
                </StackPanel>
              </UniformGrid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Footer -->
      <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
        <Button x:Name="ApplyButton" Content="Apply" DockPanel.Dock="Left" Style="{StaticResource GhostButtonStyle}" Click="ApplyButton_OnClick" />
        <Button Content="Cancel" DockPanel.Dock="Right" Margin="10,0,0,0" Style="{StaticResource GhostButtonStyle}" IsCancel="True" />
        <Button x:Name="SaveButton" Content="Save" DockPanel.Dock="Right" Style="{StaticResource PrimaryButtonStyle}" Click="SaveButton_OnClick" IsDefault="True" />
      </DockPanel>
    </Grid>
  </Border>
</Window>
